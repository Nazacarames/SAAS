APP_NAME=Charlott FastAPI
ENVIRONMENT=development
API_PREFIX=/api

# JWT Authentication
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string-at-least-32-chars

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=atendechat

# OpenAI API Key for AI Agent
OPENAI_API_KEY=your_openai_api_key_here

# Tokko Broker API for property listings
TOKKO_API_KEY=your_tokko_api_key_here
TOKKO_API_URL=https://api.tokkobroker.com/api/v1

# WhatsApp Cloud API
WHATSAPP_APP_SECRET=your_whatsapp_app_secret_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here

# Redis (for rate limiting and caching)
REDIS_URL=redis://localhost:6379
