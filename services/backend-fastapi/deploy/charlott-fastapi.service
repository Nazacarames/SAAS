[Unit]
Description=Charlott FastAPI Backend
After=network.target

[Service]
User=deploy
Group=deploy
WorkingDirectory=/home/deploy/atendechat/services/backend-fastapi
EnvironmentFile=/home/deploy/atendechat/services/backend-fastapi/.env
ExecStart=/home/deploy/atendechat/services/backend-fastapi/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 4010 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
