# Required
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random-secret
NODE_ENV=production
PORT=4000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atendechat
DB_USER=atendechat_user
DB_PASS=your-db-password

# Frontend URL (for CORS)
FRONTEND_URL=https://login.charlott.ai

# Sentry Error Tracking (optional but recommended)
SENTRY_DSN=

# WhatsApp Cloud API (set via runtime-settings.json or env)
WA_CLOUD_ACCESS_TOKEN=
WA_CLOUD_APP_SECRET=
WA_CLOUD_VERIFY_TOKEN=
WA_CLOUD_PHONE_NUMBER_ID=

# Meta Lead Ads
META_VERIFY_TOKEN=
META_APP_SECRET=
META_DEFAULT_COMPANY_ID=1

# Tokko Integration (optional)
TOKKO_API_KEY=
TOKKO_BASE_URL=https://www.tokkobroker.com/api/v1

# OpenAI / AI
OPENAI_API_KEY=
